<?xml version="1.0" encoding="UTF-8"?>
<!-- AppStream metadata for the Flatpak / Linux desktop integration.
     The component id matches the .desktop file id (in.illimitable.Docutaz).
     Validate with: appstreamcli validate in.illimitable.Docutaz.metainfo.xml -->
<component type="desktop-application">
  <id>in.illimitable.Docutaz</id>

  <name>Docutaz</name>
  <summary>Cross-platform MongoDB management GUI</summary>

  <!-- License of THIS metadata file; the program license is separate. -->
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="in.illimitable">
    <name>Illimitable Consulting Private Limited</name>
  </developer>

  <description>
    <p>
      Docutaz is a cross-platform desktop GUI for MongoDB, built for developers
      who work with documents. It runs queries through MongoDB's official mongosh
      shell, which is bundled with the Flatpak. It is built and tested against
      MongoDB 8.x and works with earlier supported releases.
    </p>
    <p>Features:</p>
    <ul>
      <li>Connect to local or remote MongoDB instances, replica sets and authenticated deployments</li>
      <li>Browse databases, collections and documents in tree, table or raw text view</li>
      <li>Run multi-statement JavaScript queries with the built-in mongosh shell</li>
      <li>Insert, edit and delete documents with a full-featured visual editor</li>
      <li>Manage indexes, users and collection structure</li>
      <li>Export query and aggregation results to JSON, CSV or XLSX</li>
      <li>Inline syntax checking flags unbalanced brackets and missing commas before you run</li>
    </ul>
  </description>

  <launchable type="desktop-id">in.illimitable.Docutaz.desktop</launchable>

  <!-- Screenshots are referenced by HTTPS URL; Flathub downloads and re-hosts
       them at build time. Before submitting to Flathub, capture each shot and
       drop the PNG into site/ with the matching filename below (so it publishes
       to the Pages URL). Capture rules: the Docutaz window ONLY (no desktop
       wallpaper, no other windows, no mouse cursor), with real data shown, all
       shots the same aspect ratio (≈1280x720, max ~1600px wide). Adjust the
       captions to match what you actually capture. The first (type="default")
       is the featured image. -->
  <screenshots>
    <screenshot type="default">
      <caption>Browsing databases and collections alongside query results</caption>
      <image>https://illimitable-consulting-private-limited.github.io/docutaz/screenshot-explorer.png</image>
    </screenshot>
    <screenshot>
      <caption>Editing a document in the visual editor</caption>
      <image>https://illimitable-consulting-private-limited.github.io/docutaz/screenshot-editor.png</image>
    </screenshot>
    <screenshot>
      <caption>Exporting results to JSON, CSV or XLSX</caption>
      <image>https://illimitable-consulting-private-limited.github.io/docutaz/screenshot-export.png</image>
    </screenshot>
    <screenshot>
      <caption>Formatting a query or aggregation</caption>
      <image>https://illimitable-consulting-private-limited.github.io/docutaz/screenshot-format.png</image>
    </screenshot>
    <screenshot>
      <caption>Catching syntax errors inline before you run</caption>
      <image>https://illimitable-consulting-private-limited.github.io/docutaz/screenshot-syntax.png</image>
    </screenshot>
  </screenshots>

  <url type="homepage">https://illimitable-consulting-private-limited.github.io/docutaz/</url>
  <url type="bugtracker">https://github.com/Illimitable-Consulting-Private-Limited/docutaz/issues</url>
  <url type="vcs-browser">https://github.com/Illimitable-Consulting-Private-Limited/docutaz</url>

  <categories>
    <category>Development</category>
    <category>Database</category>
  </categories>

  <keywords>
    <keyword>MongoDB</keyword>
    <keyword>Database</keyword>
    <keyword>NoSQL</keyword>
    <keyword>Query</keyword>
    <keyword>mongosh</keyword>
  </keywords>

  <!-- No nudity, violence, etc. An empty oars-1.1 rating means "no concerns". -->
  <content_rating type="oars-1.1" />

  <!-- Keep the newest entry's version in sync with the built tag; the release
       automation can prepend new entries here. -->
  <releases>
    <release version="2.4.0" date="2026-06-20">
      <description>
        <ul>
          <li>Inline syntax checking now flags missing object values and missing key colons</li>
          <li>A warning marker in the editor gutter marks every line with a syntax error</li>
          <li>Various GUI fixes</li>
        </ul>
      </description>
    </release>
    <release version="2.3.0" date="2026-06-19">
      <description>
        <ul>
          <li>Inline syntax checking in the query editor (brackets and missing commas)</li>
          <li>Clickable install-guide link in the Linux pre-flight dependency dialog</li>
          <li>Various GUI fixes</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
